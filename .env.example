# ============================================================
# RKS – Computer Centre and Xerox
# Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# ─────────────────────────────────────────
# LOCAL DEVELOPMENT (docker-compose)
# ─────────────────────────────────────────

# PostgreSQL container credentials (local only)
POSTGRES_USER=rks_user
POSTGRES_PASSWORD=rks_secure_pass_2024
POSTGRES_DB=rks_db
POSTGRES_PORT=5432

# Local DATABASE_URL (points to the postgres docker-compose service)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}

# ─────────────────────────────────────────
# PRODUCTION (Render + Supabase)
# ─────────────────────────────────────────

# Supabase DATABASE_URL — copy from:
#   Supabase Dashboard → Settings → Database → Connection String → URI
#
# Use the Transaction pooler (port 6543) for Render free tier:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# Or use the Direct connection (port 5432) if pooler has issues:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# ─────────────────────────────────────────
# SHARED (local + production)
# ─────────────────────────────────────────

NODE_ENV=production
PORT=5000

# JWT — use a long random secret in production
# Generate: openssl rand -base64 48
JWT_SECRET=rks_jwt_super_secret_change_this_in_production_2024
JWT_EXPIRES_IN=8h

# Timezone
TZ=Asia/Kolkata

# Logging
LOG_RETENTION_DAYS=60

# ─────────────────────────────────────────
# CORS — IMPORTANT for production
# ─────────────────────────────────────────
# Set to your Render app URL (e.g. https://shop-rks.onrender.com)
# For multiple origins, comma-separate them:
# ALLOWED_ORIGINS=https://shop-rks.onrender.com,https://yourdomain.com
ALLOWED_ORIGINS=

# ─────────────────────────────────────────
# LOCAL BACKUP SERVICE (docker-compose only)
# Not used in Render deployment — Supabase handles backups
# ─────────────────────────────────────────
BACKUP_DIR=/backups
BACKUP_SCHEDULE_HOUR=2
