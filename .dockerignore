# ─────────────────────────────────────────
# shop-rks — Root Docker Build Context Exclusions
# ─────────────────────────────────────────

# Dependencies (re-installed inside container)
**/node_modules

# Build outputs (re-built inside container)
**/dist

# Environment secrets — NEVER bake into image
.env
**/.env
**/.env.local
**/.env.*.local

# Logs
*.log
**/*.log
npm-debug.log*
yarn-error.log*

# Local-only services (not needed in single-container deploy)
backup/

# Local startup scripts
start-rks.bat

# Static assets folder (local use only)
asset/

# docker-compose (not used by Render)
docker-compose.yml

# Version control
.git
.gitignore

# OS artifacts
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# TypeScript build info
*.tsbuildinfo
