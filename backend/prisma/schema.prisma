// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ServiceCategory {
  GOVT
  PRINTING
  CARDS
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  bannedUntil  DateTime? @map("banned_until") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  transactions Transaction[]
  expenses     Expense[]
  logs         Log[]
  sessions     Session[]

  @@map("users")
  @@index([username])
  @@index([role])
}

// ─────────────────────────────────────────────────────────
// SERVICES (Service Catalog)
// ─────────────────────────────────────────────────────────

model Service {
  id           String          @id @default(uuid())
  name         String
  category     ServiceCategory
  price        Decimal         @db.Decimal(10, 2)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  transactions Transaction[]

  @@map("services")
  @@index([category])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────
// TRANSACTIONS (Income Entries)
// ─────────────────────────────────────────────────────────

model Transaction {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  serviceId  String   @map("service_id")
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2) @map("unit_price")
  totalPrice Decimal  @db.Decimal(10, 2) @map("total_price")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@map("transactions")
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([serviceId])
}

// ─────────────────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────────────────

model BankAccount {
  id        String   @id @default(uuid())
  name      String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  isCash    Boolean  @default(false) @map("is_cash")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  expenses  Expense[]

  @@map("bank_accounts")
}

model Expense {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  amount    Decimal       @db.Decimal(10, 2)
  category  String
  note      String?
  status    ExpenseStatus @default(PENDING)
  bankId    String?       @map("bank_id")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  bank BankAccount? @relation(fields: [bankId], references: [id], onDelete: SetNull)

  @@map("expenses")
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([status])
  @@index([bankId])
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("expense_categories")
}

// ─────────────────────────────────────────────────────────
// SYSTEM & SESSIONS
// ─────────────────────────────────────────────────────────

model Session {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  loginTime  DateTime  @default(now()) @map("login_time") @db.Timestamptz
  logoutTime DateTime? @map("logout_time") @db.Timestamptz
  lastSeen   DateTime  @default(now()) @map("last_seen") @db.Timestamptz
  isKicked   Boolean   @default(false) @map("is_kicked")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
  @@index([loginTime])
}

model SystemConfig {
  id                 Int      @id @default(1)
  maintenanceMode    Boolean  @default(false) @map("maintenance_mode")
  maintenanceMessage String   @default("Server is under maintenance. Please try again later.") @map("maintenance_message")
  serverMessage      String?  @map("server_message")
  version            String   @default("1.0.0")

  @@map("system_config")
}

// ─────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────

model Log {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  action    AuditAction
  tableName String      @map("table_name")
  recordId  String      @map("record_id")
  oldValue  Json?       @map("old_value")
  newValue  Json?       @map("new_value")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("logs")
  @@index([createdAt])
  @@index([userId])
  @@index([tableName])
}

